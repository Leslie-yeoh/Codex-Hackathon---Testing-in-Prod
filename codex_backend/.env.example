# MongoDB connection used by OCR storage and authentication.
MONGODB_URI=mongodb://localhost:27017

# Required for JWT authentication.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=30

# Optional OCR providers run before NVIDIA: OpenAI, Mistral, then Gemini.
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-5.6-terra
MISTRAL_API_KEY=
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key
GEMINI_API_KEY=
